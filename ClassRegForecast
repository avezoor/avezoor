    "# Target Regresi\n",
    "if tok_sold_col is None:\n",
    "    raise ValueError(\"Kolom units sold / volume penjualan tidak ditemukan. Sesuaikan kandidat kolom pada detect_column().\")\n",
    "\n",
    "task2_df = task2_df[task2_df[tok_sold_col].notna()].copy()\n",
    "task2_df[\"target_sales_potential\"] = np.log1p(task2_df[tok_sold_col].clip(lower=0))\n",
    "\n",
    "# Fitur Numerik\n",
    "numeric_feature_cols = []\n",
    "for c in [tok_price_col, tok_rating_col, \"mapping_score\"]:\n",
    "    if c is not None and c in task2_df.columns:\n",
    "        numeric_feature_cols.append(c)\n",
    "\n",
    "# Encoding Lokasi\n",
    "if tok_location_col is not None and tok_location_col in task2_df.columns:\n",
    "    top_locations = task2_df[tok_location_col].value_counts().head(20).index\n",
    "    task2_df[\"location_grouped\"] = np.where(task2_df[tok_location_col].isin(top_locations), task2_df[tok_location_col], \"other\")\n",
    "    loc_dummies = pd.get_dummies(task2_df[\"location_grouped\"], prefix=\"loc\", dtype=int)\n",
    "else:\n",
    "    loc_dummies = pd.DataFrame(index=task2_df.index)\n",
    "\n",
    "# Prior Visual\n",
    "visual_feature_cols = embedding_cols + prob_cols\n",
    "\n",
    "base_numeric = task2_df[numeric_feature_cols].copy()\n",
    "for c in numeric_feature_cols:\n",
    "    base_numeric[c] = base_numeric[c].fillna(base_numeric[c].median())\n",
    "\n",
    "X_task2 = pd.concat(\n",
    "    [\n",
    "        base_numeric.reset_index(drop=True),\n",
    "        loc_dummies.reset_index(drop=True),\n",
    "        task2_df[visual_feature_cols].reset_index(drop=True),\n",
    "    ],\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "y_task2 = task2_df[\"target_sales_potential\"].values.astype(np.float32)\n",
    "\n",
    "print(\"X_task2 shape:\", X_task2.shape)\n",
    "print(\"y_task2 shape:\", y_task2.shape)\n",
    "X_task2.head()"
   ]
