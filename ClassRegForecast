    "# Ekstraksi Fitur\n",
    "embedding_model = tf.keras.Model(\n",
    "    inputs=task1_model.input,\n",
    "    outputs=task1_model.get_layer(\"embedding\").output,\n",
    "    name=\"task1_embedding_model\"\n",
    ")\n",
    "\n",
    "def build_image_only_ds(df):\n",
    "    ds = tf.data.Dataset.from_tensor_slices(df[\"image_path\"].values)\n",
    "    def _load(path):\n",
    "        img = tf.io.read_file(path)\n",
    "        img = tf.image.decode_jpeg(img, channels=3)\n",
    "        img = tf.image.resize(img, IMG_SIZE)\n",
    "        img = tf.cast(img, tf.float32) / 255.0\n",
    "        return img\n",
    "    ds = ds.map(_load, num_parallel_calls=tf.data.AUTOTUNE)\n",
    "    ds = ds.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n",
    "    return ds\n",
    "\n",
    "all_img_ds = build_image_only_ds(task1_df)\n",
    "all_embeddings = embedding_model.predict(all_img_ds, verbose=0)\n",
    "all_probs = task1_model.predict(all_img_ds, verbose=0)\n",
    "all_pred_idx = all_probs.argmax(axis=1)\n",
    "all_pred_label = label_encoder_task1.inverse_transform(all_pred_idx)\n",
    "\n",
    "embedding_cols = [f\"emb_{i}\" for i in range(all_embeddings.shape[1])]\n",
    "prob_cols = [f\"prob_{safe_slug(c)}\" for c in class_names]\n",
    "\n",
    "task1_features_df = task1_df[[id_col, target_col, \"image_path\"]].copy()\n",
    "task1_features_df[\"pred_label\"] = all_pred_label\n",
    "task1_features_df[\"pred_confidence\"] = all_probs.max(axis=1)\n",
    "\n",
    "for i, col in enumerate(embedding_cols):\n",
    "    task1_features_df[col] = all_embeddings[:, i]\n",
    "\n",
    "for i, col in enumerate(prob_cols):\n",
    "    task1_features_df[col] = all_probs[:, i]\n",
    "\n",
    "task1_features_df.head()"
   ]
