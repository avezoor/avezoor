0","cell_type":"code","source":"IMG_SIZE = (CONFIG[\"img_height\"], CONFIG[\"img_width\"])\nBATCH_SIZE = CONFIG[\"img_batch_size\"]\n\ndef load_image_and_label(path, label):\n    img = tf.io.read_file(path)\n    img = tf.image.decode_jpeg(img, channels=3)\n    img = tf.image.resize(img, IMG_SIZE)\n    img = tf.cast(img, tf.float32) / 255.0\n    return img, label\n\ndef build_tf_dataset(df, shuffle=False):\n    ds = tf.data.Dataset.from_tensor_slices((df[\"image_path\"].values, df[\"label_id\"].values))\n    ds = ds.map(load_image_and_label, num_parallel_calls=tf.data.AUTOTUNE)\n    if shuffle:\n        ds = ds.shuffle(min(len(df), 5000), seed=SEED)\n    ds = ds.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n    return ds\n\ntrain_ds = build_tf_dataset(train_df, shuffle=True)\nval_ds = build_tf_dataset(val_df, shuffle=False)\ntest_ds = build_tf_dataset(test_df, shuffle=False)\n\nfor batch_images, batch_labels in train_ds.take(1):\n    print(batch_images.shape, batch_labels.shape)","metadata":{"execution":{"iopub.execute_input":"2026-04-24T02:11:09.210453Z","iopub.status.busy":"2026-04-24T02:11:09.209480Z","iopub.status.idle":"2026-04-24T02:12:02.698352Z","shell.execute_reply":"2026-04-24T02:12:02.697551Z"},"papermill":{"duration":53.501877,"end_time":"2026-04-24T02:12:02.700504+00:00","exception":false,"start_time":"2026-04-24T02:11:09.198627+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["(64, 128, 128, 3) (64,)\n"]}],"execution_count":8},{"id":"aa60c4c0","cell_type":"code","source":"def build_cnn_classifier(input_shape=(128, 128, 3), num_classes=10, embedding_dim=128):\n    inputs = tf.keras.Input(shape=input_shape, name=\"image\")\n\n    x = tf.keras.layers.Conv2D(32, 3, padding=\"same\", activation=\"relu\")(inputs)\n    x = tf.keras.layers.MaxPooling2D()(x)\n\n    x = tf.keras.layers.Conv2D(64, 3, padding=\"same\", activation=\"relu\")(x)\n    x = tf.keras.layers.MaxPooling2D()(x)\n\n    x = tf.keras.layers.Conv2D(128, 3, padding=\"same\", activation=\"relu\")(x)\n    x = tf.keras.layers.MaxPooling2D()(x)\n\n    x = tf.keras.layers.Conv2D(256, 3, padding=\"same\", activation=\"relu\")(x)\n    x = tf.keras.layers.GlobalAveragePooling2D()(x)\n\n    x = tf.keras.layers.Dense(256, activation=\"relu\")(x)\n    x = tf.keras.layers.Dropout(0.3)(x)\n\n    embedding = tf.keras.layers.Dense(embedding_dim, activation=\"relu\", name=\"embedding\")(x)\n    outputs = tf.keras.layers.Dense(num_classes, activation=\"softmax\", name=\"class_prob\")(embedding)\n\n    model = tf.keras.Model(inputs=inputs, outputs=outputs, name=\"cnn_classifier\")\n    return model\n\ntask1_model = build_cnn_classifier(\n    input_shape=(CONFIG[\"img_height\"], CONFIG[\"img_width\"], 3),\n    num_classes=num_classes,\n    embedding_dim=CONFIG[\"img_embedding_dim\"],\n)\n\ntask1_model.compile(\n    optimizer=tf.keras.optimizers.Adam(1e-3),\n    loss=\"sparse_categorical_crossentropy\",\n    metrics=[\"accuracy\"],\n)\n\ntask1_model.summary()","metadata":{"execution":{"iopub.execute_input":"2026-04-24T02:12:02.722018Z","iopub.status.busy":"2026-04-24T02:12:02.721710Z","iopub.status.idle":"2026-04-24T02:12:02.851185Z","shell.execute_reply":"2026-04-24T02:12:02.850226Z"},"papermill":{"duration":0.142559,"end_time":"2026-04-24T02:12:02.852940+00:00","exception":false,"start_time":"2026-04-24T02:12:02.710381+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"cnn_classifier\"</span>\n","</pre>\n"],"text/plain":["\u001b[1mModel: \"cnn_classifier\"\u001b[0m\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━