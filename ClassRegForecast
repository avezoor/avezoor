    "def build_mlp_regressor(input_dim):\n",
    "    inputs = tf.keras.Input(shape=(input_dim,), name=\"tabular_input\")\n",
    "    x = tf.keras.layers.Dense(256, activation=\"relu\")(inputs)\n",
    "    x = tf.keras.layers.BatchNormalization()(x)\n",
    "    x = tf.keras.layers.Dropout(0.25)(x)\n",
    "\n",
    "    x = tf.keras.layers.Dense(128, activation=\"relu\")(x)\n",
    "    x = tf.keras.layers.BatchNormalization()(x)\n",
    "    x = tf.keras.layers.Dropout(0.20)(x)\n",
    "\n",
    "    x = tf.keras.layers.Dense(64, activation=\"relu\")(x)\n",
    "    outputs = tf.keras.layers.Dense(1, activation=\"linear\", name=\"sales_potential\")(x)\n",
    "\n",
    "    model = tf.keras.Model(inputs=inputs, outputs=outputs, name=\"mlp_regressor\")\n",
    "    return model\n",
    "\n",
    "task2_model = build_mlp_regressor(X2_train_sc.shape[1])\n",
    "task2_model.compile(\n",
    "    optimizer=tf.keras.optimizers.Adam(1e-3),\n",
    "    loss=\"mse\",\n",
    "    metrics=[\"mae\"]\n",
    ")\n",
    "task2_model.summary()"
   ]
