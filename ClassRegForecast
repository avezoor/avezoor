    "def normalize_colname(col):\n",
    "    return re.sub(r\"[^a-z0-9]+\", \"_\", str(col).strip().lower()).strip(\"_\")\n",
    "\n",
    "def get_search_roots():\n",
    "    candidates = [\n",
    "        Path.cwd(),\n",
    "        Path.cwd() / \"data\",\n",
    "        Path.cwd() / \"input\",\n",
    "        Path.cwd().parent / \"input\",\n",
    "        Path(\"/kaggle/input\"),\n",
    "        Path(\"/kaggle/working\"),\n",
    "        Path(\"./data\"),\n",
    "        Path(\"./input\"),\n",
    "        Path(\"../input\"),\n",
    "    ]\n",
    "\n",
    "    roots = []\n",
    "    seen = set()\n",
    "    for candidate in candidates:\n",
    "        candidate = Path(candidate)\n",
    "        try:\n",
    "            key = str(candidate.resolve(strict=False))\n",
    "        except Exception:\n",
    "            key = str(candidate)\n",
    "        if key not in seen and candidate.exists():\n",
    "            seen.add(key)\n",
    "            roots.append(candidate)\n",
    "    return roots\n",
    "\n",
    "def resolve_file_path(config_value, required_name=None, keywords=None):\n",
    "    raw_path = Path(config_value)\n",
    "    candidates = [raw_path]\n",
    "    if required_name:\n",
    "        candidates.append(Path(required_name))\n",
    "\n",
    "    for root in get_search_roots():\n",
    "        candidates.append(root / raw_path)\n",
    "        if required_name:\n",
    "            candidates.append(root / required_name)\n",
    "            candidates.extend(root.rglob(required_name))\n",
    "\n",
    "    seen = set()\n",
    "    for candidate in candidates:\n",
    "        candidate = Path(candidate)\n",
    "        try:\n",
    "            key = str(candidate.resolve(strict=False))\n",
    "        except Exception:\n",
    "            key = str(candidate)\n",
    "        if key in seen:\n",
    "            continue\n",
    "        seen.add(key)\n",
    "        if candidate.exists() and candidate.is_file():\n",
    "            return candidate\n",
    "\n",
    "    keywords = [k.lower() for k in (keywords or []) if k]\n",
    "    if keywords:\n",
    "        for root in get_search_roots():\n",
    "            for csv_path in root.rglob(\"*.csv\"):\n",
    "                path_text = str(csv_path).lower().replace(\"\\\\\", \"/\")\n",
    "                if all(keyword in path_text for keyword in keywords):\n",
    "                    return csv_path\n",
    "    raise FileNotFoundError(f\"File tidak ditemukan untuk config path: {config_value}\")\n",
    "\n",
    "def resolve_fashion_assets(config_root, config_styles, config_images):\n",
    "    styles_path = Path(config_styles)\n",
    "    images_dir = Path(config_images)\n",
    "    if styles_path.exists() and images_dir.exists():\n",
    "        return styles_path.parent, styles_path, images_dir\n",
    "\n",
    "    root_candidates = [Path(config_root)]\n",
    "    for root in get_search_roots():\n",
    "        root_candidates.append(root / Path(config_root))\n",
    "\n",
    "    for root_candidate in root_candidates:\n",
    "        if (root_candidate / \"styles.csv\").exists() and (root_candidate / \"images\").exists():\n",
    "            return root_candidate, root_candidate / \"styles.csv\", root_candidate / \"images\"\n",
    "\n",
    "    for root in get_search_roots():\n",
    "        for styles_candidate in root.rglob(\"styles.csv\"):\n",
    "            parent = styles_candidate.parent\n",
    "            images_candidate = parent / \"images\"\n",
    "            parent_text = str(parent).lower().replace(\"\\\\\", \"/\")\n",
    "            if images_candidate.exists() and \"fashion\" in parent_text:\n",
    "                return parent, styles_candidate, images_candidate\n",
    "\n",
    "    raise FileNotFoundError(\n",
    "        \"Dataset fashion tidak ditemukan. Pastikan folder berisi styles.csv dan subfolder images tersedia.\"\n",
    "    )\n",
    "\n",
    "\n",
    "\n",
    "def read_csv_smart(path, **kwargs):\n",
    "    path = Path(path)\n",
    "    encodings = [\"utf-8-sig\", \"utf-8\", \"latin1\"]\n",
    "    seps = [None, \";\", \",\", \"\\t\", \"|\"]\n",
    "\n",
    "    best_df = None\n",
    "    best_score = -1\n",
    "    best_info = None\n",
    "    last_error = None\n",
    "\n",
    "    for enc in encodings:\n",
    "        for sep in seps:\n",
    "            try:\n",
    "                read_kwargs = dict(kwargs)\n",
    "                read_kwargs.setdefault(\"on_bad_lines\", \"skip\")\n",
    "                read_kwargs[\"encoding\"] = enc\n",
    "                if sep is None:\n",
    "                    read_kwargs[\"sep\"] = None\n",
    "                    read_kwargs[\"engine\"] = \"python\"\n",
    "                else:\n",
    "                    read_kwargs[\"sep\"] = sep\n",
    "                df_try = pd.read_csv(path, **read_kwargs)\n",
    "                score = df_try.shape[1]\n",
    "                # Penalti jika cuma satu kolom berisi delimiter umum di header.\n",
    "                if score == 1 and any(d in str(df_try.columns[0]) for d in [\";\", \"|\", \"\\t\"]):\n",
    "                    score = 0\n",
    "                if score > best_score:\n",
    "                    best_df = df_try\n",
    "                    best_score = score\n",
    "                    best_info = {\"encoding\": enc, \"sep\": \"auto\" if sep is None else sep, \"shape\": df_try.shape}\n",
    "            except Exception as exc:\n",
    "                last_error = exc\n",
    "\n",
    "    if best_df is None:\n",
    "        raise last_error if last_error is not None else ValueError(f\"Gagal membaca CSV: {path}\")\n",
    "\n",
    "    print(\"CSV reader info:\", best_info)\n",
    "    return best_df\n",
    "\n",
    "def normalize_columns(df):\n",
    "    df = df.copy()\n",
    "    df.columns = [normalize_colname(c) for c in df.columns]\n",
    "    return df\n",
    "\n",
    "def detect_column(df, candidates, required=False):\n",
    "    cols = list(df.columns)\n",
    "    for cand in candidates:\n",
    "        cand_norm = normalize_colname(cand)\n",
    "        if cand_norm in cols:\n",
    "            return cand_norm\n",
    "\n",
    "    # pencarian fuzzy sederhana\n",
    "    for col in cols:\n",
    "        for cand in candidates:\n",
    "            cand_norm = normalize_colname(cand)\n",
    "            if cand_norm in col or col in cand_norm:\n",
    "                return col\n",
    "\n",
    "    if required:\n",
    "        raise ValueError(f\"Tidak menemukan kolom yang cocok untuk kandidat: {candidates}\")\n",
    "    return None\n",
    "\n",
    "def clean_numeric_series(s):\n",
    "    if s is None:\n",
    "        return None\n",
    "    if pd.api.types.is_numeric_dtype(s):\n",
    "        return pd.to_numeric(s, errors=\"coerce\")\n",
    "    s = s.astype(str)\n",
    "    s = s.str.replace(r\"[^0-9,.-]\", \"\", regex=True)\n",
    "    # ubah koma ribuan/desimal secara cukup aman\n",
    "    s = s.str.replace(\".\", \"\", regex=False).str.replace(\",\", \".\", regex=False)\n",
    "    return pd.to_numeric(s, errors=\"coerce\")\n",
    "\n",
    "def save_figure(filename, dpi=160):\n",
    "    fig_dir = Path(CONFIG[\"fig_dir\"])\n",
    "    fig_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    filename = str(filename)\n",
    "    if not filename.lower().endswith((\".png\", \".jpg\", \".jpeg\", \".pdf\", \".svg\")):\n",
    "        filename = f\"{filename}.png\"\n",
    "\n",
    "    path = fig_dir / filename\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(path, dpi=dpi, bbox_inches=\"tight\")\n",
    "    print(\"Saved figure:\", path)\n",
    "    return path\n",
    "\n",
    "def plot_history(history, metric_pairs=None, title_prefix=\"Model\", save_prefix=None):\n",
    "    hist = pd.DataFrame(history.history)\n",
    "    metric_pairs = metric_pairs or [\n",
    "        (\"loss\", \"val_loss\"),\n",
    "        (\"accuracy\", \"val_accuracy\"),\n",
    "    ]\n",
    "    saved_paths = []\n",
    "    for train_metric, val_metric in metric_pairs:\n",
    "        if train_metric in hist.columns and val_metric in hist.columns:\n",
    "            plt.figure(figsize=(7,4))\n",
    "            plt.plot(hist[train_metric], label=train_metric)\n",
    "            plt.plot(hist[val_metric], label=val_metric)\n",
    "            plt.title(f\"{title_prefix}: {train_metric} vs {val_metric}\")\n",
    "            plt.xlabel(\"Epoch\")\n",
    "            plt.ylabel(train_metric)\n",
    "            plt.legend()\n",
    "            plt.grid(alpha=0.3)\n",
    "            if save_prefix is not None:\n",
    "                metric_slug = safe_slug(f\"{train_metric}_vs_{val_metric}\")\n",
    "                saved_paths.append(save_figure(f\"{save_prefix}_{metric_slug}.png\"))\n",
    "            plt.show()\n",
    "    return saved_paths\n",
    "\n",
    "def safe_slug(text):\n",
    "    text = str(text).strip().lower()\n",
    "    text = re.sub(r\"[^a-z0-9]+\", \"_\", text)\n",
    "    return text.strip(\"_\")\n",
    "\n",
    "def tokenize_text(text):\n",
    "    text = str(text).lower()\n",
    "    tokens = re.findall(r\"[a-z0-9]+\", text)\n",
    "    return set(tokens)\n",
    "\n",
    "def best_label_match(text, label_list):\n",
    "    '''\n",
    "    Bridge sederhana antar dataset:\n",
    "    memilih label Task 1 berdasarkan overlap token dari nama/kategori produk.\n",
    "    '''\n",
    "    text_tokens = tokenize_text(text)\n",
    "    if len(text_tokens) == 0:\n",
    "        return None, 0\n",
    "\n",
    "    best_label = None\n",
    "    best_score = -1\n",
    "\n",
    "    for label in label_list:\n",
    "        label_tokens = tokenize_text(label)\n",
    "        if not label_tokens:\n",
    "            continue\n",
    "        score = len(text_tokens & label_tokens)\n",
    "        # bonus jika label menjadi substring dari text\n",
    "        if str(label).lower() in str(text).lower():\n",
    "            score += 2\n",
    "        if score > best_score:\n",
    "            best_score = score\n",
    "            best_label = label\n",
    "\n",
    "    return best_label, best_score\n",
    "\n",
    "def make_supervised_windows(values, window=6, horizon=3, extra_feature=None):\n",
    "    '''\n",
    "    values: array 1D target time series\n",
    "    extra_feature: skalar atau array 1D dengan panjang sama\n",
    "    output:\n",
    "        X -> (n_samples, window, channels)\n",
    "        y -> (n_samples, horizon)\n",
    "    '''\n",
    "    values = np.asarray(values, dtype=np.float32)\n",
    "    if extra_feature is None:\n",
    "        extra_feature = np.zeros_like(values, dtype=np.float32)\n",
    "    elif np.isscalar(extra_feature):\n",
    "        extra_feature = np.full_like(values, float(extra_feature), dtype=np.float32)\n",
    "    else:\n",
    "        extra_feature = np.asarray(extra_feature, dtype=np.float32)\n",
    "\n",
    "    X, y = [], []\n",
    "    for i in range(len(values) - window - horizon + 1):\n",
    "        past_values = values[i:i+window]\n",
    "        past_extra = extra_feature[i:i+window]\n",
    "        X_i = np.stack([past_values, past_extra], axis=-1)\n",
    "        y_i = values[i+window:i+window+horizon]\n",
    "        X.append(X_i)\n",
    "        y.append(y_i)\n",
    "\n",
    "    return np.asarray(X), np.asarray(y)\n",
    "\n",
    "def chron_split(X, y, train_ratio=0.7, val_ratio=0.15):\n",
    "    n = len(X)\n",
    "    train_end = int(n * train_ratio)\n",
    "    val_end = int(n * (train_ratio + val_ratio))\n",
    "    return (\n",
    "        X[:train_end], y[:train_end],\n",
    "        X[train_end:val_end], y[train_end:val_end],\n",
    "        X[val_end:], y[val_end:]\n",
    "    )\n",
    "\n",
    "\n",
    "def plot_keras_history_complete(history, title_prefix=\"Model\", save_prefix=\"training_history\", metrics=None):\n",
    "    hist = pd.DataFrame(history.history).copy()\n",
    "    hist.insert(0, \"epoch\", np.arange(1, len(hist) + 1))\n",
    "\n",
    "    output_dir = Path(CONFIG[\"output_dir\"])\n",
    "    fig_dir = Path(CONFIG[\"fig_dir\"])\n",
    "    output_dir.mkdir(parents=True, exist_ok=True)\n",
    "    fig_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    csv_path = output_dir / f\"{save_prefix}_history.csv\"\n",
    "    hist.to_csv(csv_path, index=False)\n",
    "    print(\"Saved history CSV:\", csv_path)\n",
    "\n",
    "    # Tentukan metric utama selain loss.\n",
    "    if metrics is None:\n",
    "        candidate_metrics = [\"accuracy\", \"acc\", \"mae\", \"mse\", \"rmse\"]\n",
    "        metrics = [m for m in candidate_metrics if m in hist.columns]\n",
    "    metrics = list(dict.fromkeys(metrics))\n",
    "\n",
    "    saved_paths = []\n",
    "\n",
    "    def _best_epoch(metric_name, mode):\n",
    "        if metric_name not in hist.columns:\n",
    "            return None, None\n",
    "        values = hist[metric_name].astype(float)\n",
    "        idx = values.idxmin() if mode == \"min\" else values.idxmax()\n",
    "        return int(hist.loc[idx, \"epoch\"]), float(hist.loc[idx, metric_name])\n",
    "\n",
    "    # 1) Loss vs epoch lengkap.\n",
    "    if \"loss\" in hist.columns:\n",
    "        plt.figure(figsize=(9, 5))\n",
    "        plt.plot(hist[\"epoch\"], hist[\"loss\"], marker=\"o\", label=\"Train Loss\")\n",
    "        if \"val_loss\" in hist.columns:\n",
    "            plt.plot(hist[\"epoch\"], hist[\"val_loss\"], marker=\"o\", label=\"Validation Loss\")\n",
    "            best_epoch, best_value = _best_epoch(\"val_loss\", \"min\")\n",
    "            plt.axvline(best_epoch, linestyle=\"--\", alpha=0.6, label=f\"Best Val Loss Epoch {best_epoch}\")\n",
    "            plt.scatter([best_epoch], [best_value], zorder=5)\n",
    "        plt.title(f\"{title_prefix}: Loss vs Epoch\")\n",
    "        plt.xlabel(\"Epoch\")\n",
    "        plt.ylabel(\"Loss\")\n",
    "        plt.xticks(hist[\"epoch\"])\n",
    "        plt.legend()\n",
    "        plt.grid(alpha=0.3)\n",
    "        saved_paths.append(save_figure(f\"{save_prefix}_loss_vs_epoch.png\"))\n",
    "        plt.show()\n",
    "\n",
    "    # 2) Metric utama vs epoch lengkap, misalnya accuracy atau MAE.\n",
    "    for metric in metrics:\n",
    "        val_metric = f\"val_{metric}\"\n",
    "        plt.figure(figsize=(9, 5))\n",
    "        plt.plot(hist[\"epoch\"], hist[metric], marker=\"o\", label=f\"Train {metric}\")\n",
    "        if val_metric in hist.columns:\n",
    "            plt.plot(hist[\"epoch\"], hist[val_metric], marker=\"o\", label=f\"Validation {metric}\")\n",
    "            maximize = metric in [\"accuracy\", \"acc\"]\n",
    "            best_epoch, best_value = _best_epoch(val_metric, \"max\" if maximize else \"min\")\n",
    "            label_text = f\"Best Val {metric} Epoch {best_epoch}\"\n",
    "            plt.axvline(best_epoch, linestyle=\"--\", alpha=0.6, label=label_text)\n",
    "            plt.scatter([best_epoch], [best_value], zorder=5)\n",
    "        pretty_metric = metric.upper() if metric in [\"mae\", \"mse\", \"rmse\"] else metric.capitalize()\n",
    "        plt.title(f\"{title_prefix}: {pretty_metric} vs Epoch\")\n",
    "        plt.xlabel(\"Epoch\")\n",
    "        plt.ylabel(pretty_metric)\n",
    "        plt.xticks(hist[\"epoch\"])\n",
    "        plt.legend()\n",
    "        plt.grid(alpha=0.3)\n",
    "        saved_paths.append(save_figure(f\"{save_prefix}_{safe_slug(metric)}_vs_epoch.png\"))\n",
    "        plt.show()\n",
    "\n",
    "    # 3) Ringkasan dua panel untuk laporan.\n",
    "    if \"loss\" in hist.columns and metrics:\n",
    "        metric = metrics[0]\n",
    "        val_metric = f\"val_{metric}\"\n",
    "        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "        axes[0].plot(hist[\"epoch\"], hist[\"loss\"], marker=\"o\", label=\"Train Loss\")\n",
    "        if \"val_loss\" in hist.columns:\n",
    "            axes[0].plot(hist[\"epoch\"], hist[\"val_loss\"], marker=\"o\", label=\"Validation Loss\")\n",
    "        axes[0].set_title(\"Loss vs Epoch\")\n",
    "        axes[0].set_xlabel(\"Epoch\")\n",
    "        axes[0].set_ylabel(\"Loss\")\n",
    "        axes[0].set_xticks(hist[\"epoch\"])\n",
    "        axes[0].legend()\n",
    "        axes[0].grid(alpha=0.3)\n",
    "\n",
    "        axes[1].plot(hist[\"epoch\"], hist[metric], marker=\"o\", label=f\"Train {metric}\")\n",
    "        if val_metric in hist.columns:\n",
    "            axes[1].plot(hist[\"epoch\"], hist[val_metric], marker=\"o\", label=f\"Validation {metric}\")\n",
    "        pretty_metric = metric.upper() if metric in [\"mae\", \"mse\", \"rmse\"] else metric.capitalize()\n",
    "        axes[1].set_title(f\"{pretty_metric} vs Epoch\")\n",
    "        axes[1].set_xlabel(\"Epoch\")\n",
    "        axes[1].set_ylabel(pretty_metric)\n",
    "        axes[1].set_xticks(hist[\"epoch\"])\n",
    "        axes[1].legend()\n",
    "        axes[1].grid(alpha=0.3)\n",
    "\n",
    "        fig.suptitle(f\"{title_prefix}: Training Curves\", y=1.03)\n",
    "        plt.tight_layout()\n",
    "        saved_paths.append(save_figure(f\"{save_prefix}_combined_training_curves.png\"))\n",
    "        plt.show()\n",
    "\n",
    "    display(hist)\n",
    "    return hist, saved_paths\n"
   ]
